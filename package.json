{
  "name": "@usetransactional/better-auth",
  "version": "0.1.0",
  "description": "Better Auth plugin for Transactional Auth",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "better-auth",
    "transactional",
    "auth",
    "oauth",
    "oidc",
    "plugin"
  ],
  "author": "Transactional HQ <hello@usetransactional.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TransactionalHQ/better-auth.git"
  },
  "homepage": "https://usetransactional.com/docs/auth/better-auth",
  "bugs": {
    "url": "https://github.com/TransactionalHQ/better-auth/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependencies": {
    "better-auth": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "better-auth": "^1.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
